generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String?     @unique
  password   String?
  registerNumber String? @unique
  year       Int?
  role       String      // STUDENT, ADMIN, STAFF
  department String?
  complaints Complaint[]
}

model Location {
  id       String     @id @default(auto()) @map("_id") @db.ObjectId // e.g. BLOCK_A, DEPT_CSE, LAB_204
  name     String
  type     String     // BLOCK, DEPARTMENT, LAB, CLASSROOM
  parentId String?    @db.ObjectId
  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Location[] @relation("LocationHierarchy")
  assets   Asset[]
  x        Float?     // Coordinates for Digital Twin Map
  y        Float?
}

model Asset {
  id                        String             @id @default(auto()) @map("_id") @db.ObjectId
  name                      String
  type                      String             // HVAC, IT, ELECTRICAL, PLUMBING
  locationId                String             @db.ObjectId
  location                  Location           @relation(fields: [locationId], references: [id])
  status                    String             // HEALTHY, WARNING, CRITICAL
  
  // Complaint DNA Enhancements
  reliabilityScore          Float
  failureCount              Int                @default(0)
  lastFailureDate           DateTime?
  maintenanceCostEstimate   Float              @default(0)
  replacementRecommendation Boolean            @default(false)
  
  maintenanceLogs           MaintenanceLog[]
  complaints                Complaint[]
  dependencies              AssetDependency[]  @relation("DependentOn")
  dependentOn               AssetDependency[]  @relation("DependencyOf")
}

model AssetDependency {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  assetId         String @db.ObjectId
  dependentOnId   String @db.ObjectId
  asset           Asset  @relation("DependentOn", fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  dependentOnAsset Asset @relation("DependencyOf", fields: [dependentOnId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Complaint {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  category      String          @default("INFRASTRUCTURE")
  priority      String          @default("MEDIUM")
  status        String          // OPEN, IN_PROGRESS, RESOLVED
  imageUrl      String?
  userId        String          @db.ObjectId
  user          User            @relation(fields: [userId], references: [id])
  assetId       String?         @db.ObjectId
  asset         Asset?          @relation(fields: [assetId], references: [id])
  clusterId     String?         @db.ObjectId
  cluster       ProblemCluster? @relation(fields: [clusterId], references: [id])
  createdAt     DateTime        @default(now())
  resolvedAt    DateTime?
  resolutionNote String?
  resolutionImageUrl String?
  checklist     String?
  escalationLevel String @default("NONE") // NONE, DEPT_ADMIN, HEAD, PRINCIPAL
}

model ProblemCluster {
  id                       String      @id @default(auto()) @map("_id") @db.ObjectId
  rootCauseId              String?     @db.ObjectId
  confidence               Float       // Root Cause Confidence Score
  status                   String      // ACTIVE, RESOLVED
  complaints               Complaint[]
  
  // Ripple Impact Predictor Enhancements
  affectedStudentsCount    Int         @default(0)
  affectedLocationsCount   Int         @default(0)
  affectedServicesCount    Int         @default(0)
  impactSeverityScore      Float       @default(0) // 0 to 10
  estimatedDisruptionLevel String      // LOW, MEDIUM, HIGH, CRITICAL

  createdAt                DateTime    @default(now())
  resolvedAt               DateTime?
}

model MaintenanceLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId     String   @db.ObjectId
  asset       Asset    @relation(fields: [assetId], references: [id])
  date        DateTime @default(now())
  action      String   // REPAIRED, REPLACED, INSPECTED
  cost        Float    @default(0)
  notes       String?
}
