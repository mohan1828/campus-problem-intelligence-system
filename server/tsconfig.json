{
  "compilerOptions": {
    "types": ["node"],
    "target": "es2022",
    "module": "node16",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node16"
  }
}